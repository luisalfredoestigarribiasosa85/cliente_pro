<% content_for :page_title, @customer.name %>

<div class="mb-6">
  <%= link_to customers_path, class: "text-sm text-gray-500 hover:text-gray-700 flex items-center gap-1" do %>
    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
    Volver a clientes
  <% end %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Customer Info -->
  <div class="lg:col-span-2">
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <div class="flex items-start justify-between mb-6">
        <div>
          <h2 class="text-xl font-semibold text-gray-900"><%= @customer.name %></h2>
          <p class="text-sm text-gray-500 mt-1"><%= @customer.phone %></p>
        </div>
        <div class="flex items-center gap-2">
          <%= status_badge(@customer.status) %>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wider">Último Contacto</p>
          <p class="text-sm font-medium text-gray-900 mt-1">
            <% if @customer.last_contact_date %>
              <%= @customer.last_contact_date.strftime("%d de %B, %Y") %>
              <% if @customer.needs_follow_up? %>
                <span class="ml-2 text-xs text-red-600">(<%= @customer.last_contact_days_ago %> días sin contacto)</span>
              <% end %>
            <% else %>
              <span class="text-gray-400">Sin registro</span>
            <% end %>
          </p>
        </div>
        <div>
          <p class="text-xs text-gray-500 uppercase tracking-wider">Fecha de Registro</p>
          <p class="text-sm font-medium text-gray-900 mt-1"><%= @customer.created_at.strftime("%d de %B, %Y") %></p>
        </div>
      </div>

      <% if @customer.notes.present? %>
        <div class="mb-6">
          <h3 class="text-sm font-medium text-gray-900 mb-2">Notas</h3>
          <p class="text-sm text-gray-600 bg-gray-50 rounded-lg p-4"><%= simple_format @customer.notes %></p>
        </div>
      <% end %>

      <!-- WhatsApp Actions -->
      <div class="border-t border-gray-200 pt-6">
        <h3 class="text-sm font-medium text-gray-900 mb-3">Acciones Rápidas</h3>
        <div class="flex flex-wrap gap-3">
          <a href="<%= @customer.whatsapp_link %>" target="_blank" rel="noopener" class="inline-flex items-center px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-green-600 hover:bg-green-700">
            <svg class="mr-2 h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Abrir WhatsApp
          </a>
          <%= link_to "Editar Cliente", edit_customer_path(@customer), class: "inline-flex items-center px-4 py-2 border border-gray-300 rounded-lg shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50" %>
        </div>

        <!-- Quick Message Templates -->
        <% if current_user.message_templates.any? %>
          <div class="mt-4" data-controller="clipboard" data-clipboard-text-value="">
            <h4 class="text-sm font-medium text-gray-700 mb-2">Enviar desde plantilla:</h4>
            <div class="space-y-2">
              <% current_user.message_templates.each do |template| %>
                <div class="flex items-center gap-2">
                  <button data-action="click->clipboard#copy" data-clipboard-text-value="<%= template.content.gsub('{{nombre}}', @customer.name).gsub('{{telefono}}', @customer.phone) %>" class="inline-flex items-center px-3 py-1.5 border border-gray-200 rounded-md text-xs font-medium text-gray-700 bg-white hover:bg-gray-50 hover:text-indigo-600">
                    <%= template.title %>
                  </button>
                  <span class="text-xs text-gray-400 truncate max-w-xs"><%= template.content.truncate(40) %></span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Notes History -->
    <div class="bg-white rounded-xl border border-gray-200 p-6 mt-6">
      <h3 class="text-base font-semibold text-gray-900 mb-4">Notas</h3>
      <div class="prose prose-sm max-w-none">
        <% if @customer.notes.present? %>
          <%= simple_format @customer.notes, class: "text-gray-600" %>
        <% else %>
          <p class="text-gray-400 italic">Sin notas registradas.</p>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="lg:col-span-1">
    <!-- Quick Reminder -->
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h3 class="text-sm font-medium text-gray-900 mb-4">Crear Recordatorio</h3>
      <%= form_with model: [@customer, Reminder.new], url: reminders_path, class: "space-y-3" do |f| %>
        <%= f.hidden_field :customer_id, value: @customer.id %>
        <div>
          <%= f.label :message, "Mensaje", class: "block text-xs font-medium text-gray-700 mb-1" %>
          <%= f.text_area :message, rows: 2, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm", placeholder: "¿Qué necesitas recordar?", required: true %>
        </div>
        <div>
          <%= f.label :remind_at, "Fecha/Hora", class: "block text-xs font-medium text-gray-700 mb-1" %>
          <%= f.datetime_local_field :remind_at, class: "block w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm", required: true %>
        </div>
        <%= f.submit "Crear Recordatorio", class: "w-full inline-flex justify-center items-center px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700" %>
      <% end %>
    </div>

    <!-- Recent Reminders -->
    <div class="bg-white rounded-xl border border-gray-200 p-6 mt-6">
      <h3 class="text-sm font-medium text-gray-900 mb-4">Recordatorios Recientes</h3>
      <div class="space-y-3">
        <% @reminders.each do |reminder| %>
          <div class="flex items-start gap-2">
            <div class="flex-shrink-0 mt-1">
              <%= link_to toggle_done_reminder_path(reminder), data: { turbo_method: :patch } do %>
                <% if reminder.done %>
                  <svg class="h-4 w-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <% else %>
                  <svg class="h-4 w-4 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                <% end %>
              <% end %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-gray-900 truncate"><%= reminder.message %></p>
              <p class="text-xs text-gray-500"><%= reminder.remind_at.strftime("%d/%m %H:%M") %></p>
            </div>
          </div>
        <% end %>
        <% if @reminders.empty? %>
          <p class="text-sm text-gray-400 italic">Sin recordatorios.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>