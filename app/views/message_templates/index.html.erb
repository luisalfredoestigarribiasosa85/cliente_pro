<% content_for :page_title, "Plantillas" %>

<div class="sm:flex sm:items-center sm:justify-between mb-6">
  <div class="sm:flex-auto">
    <p class="text-sm text-gray-500">Plantillas de mensajes para copiar y pegar en WhatsApp.</p>
  </div>
  <div class="mt-4 sm:mt-0">
    <%= link_to "Nueva Plantilla", new_message_template_path, class: "inline-flex items-center px-4 py-2 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700" %>
  </div>
</div>

<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3" data-controller="clipboard">
  <% @templates.each do |template| %>
    <div class="bg-white rounded-xl border border-gray-200 p-5 hover:shadow-sm transition-shadow">
      <div class="flex items-start justify-between mb-3">
        <h3 class="text-sm font-semibold text-gray-900"><%= template.title %></h3>
        <div class="flex items-center gap-1">
          <%= link_to edit_message_template_path(template), class: "p-1 text-gray-400 hover:text-indigo-600" do %>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" /></svg>
          <% end %>
          <%= link_to message_template_path(template), data: { turbo_method: :delete, turbo_confirm: "¿Eliminar plantilla?" }, class: "p-1 text-gray-400 hover:text-red-600" do %>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" /></svg>
          <% end %>
        </div>
      </div>
      <p class="text-sm text-gray-600 mb-4 min-h-[3rem]"><%= template.content.truncate(120) %></p>
      <button data-action="click->clipboard#copy" data-clipboard-text-value="<%= template.content %>" class="inline-flex items-center px-3 py-1.5 border border-gray-200 rounded-md text-xs font-medium text-gray-700 bg-white hover:bg-gray-50 hover:text-indigo-600 w-full justify-center">
        <svg class="mr-1.5 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.666 3.888A2.25 2.25 0 0013.5 2.25h-3c-1.03 0-1.9.693-2.166 1.638m7.332 0c.055.194.084.4.084.612v0a.75.75 0 01-.75.75H9a.75.75 0 01-.75-.75v0c0-.212.03-.418.084-.612m7.332 0c.646.049 1.288.11 1.927.184 1.1.128 1.907 1.077 1.907 2.185V19.5a2.25 2.25 0 01-2.25 2.25H6.75A2.25 2.25 0 014.5 19.5V6.257c0-1.108.806-2.057 1.907-2.185a48.208 48.208 0 011.927-.184" /></svg>
        Copiar mensaje
      </button>
    </div>
  <% end %>

  <% if @templates.empty? %>
    <div class="col-span-full text-center py-12">
      <p class="text-sm text-gray-500 mb-2">No hay plantillas todavía.</p>
      <p class="text-sm text-gray-400 mb-4">Crea plantillas para mensajes comunes de WhatsApp y cópialos con un clic.</p>
      <%= link_to "Crear primera plantilla", new_message_template_path, class: "text-indigo-600 hover:text-indigo-500 font-medium" %>
    </div>
  <% end %>
</div>