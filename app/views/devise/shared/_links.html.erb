<%- if controller_name != 'sessions' %>
  <p class="mt-2"><%= link_to "Iniciar sesión", new_session_path(resource_name), class: "font-medium text-indigo-600 hover:text-indigo-500" %></p>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <p class="mt-2"><%= link_to "Crear cuenta", new_registration_path(resource_name), class: "font-medium text-indigo-600 hover:text-indigo-500" %></p>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <p class="mt-2"><%= link_to "¿Olvidaste tu contraseña?", new_password_path(resource_name), class: "text-gray-500 hover:text-gray-700" %></p>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <p class="mt-2"><%= link_to "¿No recibiste instrucciones de confirmación?", new_confirmation_path(resource_name) %></p>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <p class="mt-2"><%= link_to "¿No recibiste instrucciones de desbloqueo?", new_unlock_path(resource_name) %></p>
<% end %>

<%- if devise_mapping.omniauthable? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <p class="mt-2"><%= button_to "Iniciar sesión con #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "font-medium text-indigo-600 hover:text-indigo-500" %></p>
  <% end %>
<% end %>