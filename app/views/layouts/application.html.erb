<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ClientePro</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50">
    <% if user_signed_in? %>
      <div class="min-h-screen flex">
        <!-- Sidebar -->
        <%= render "shared/sidebar" %>

        <!-- Main content -->
        <div class="flex-1 flex flex-col lg:pl-64">
          <!-- Top bar -->
          <header class="bg-white border-b border-gray-200 lg:fixed lg:left-64 lg:right-0 lg:top-0 z-10">
            <div class="px-4 sm:px-6 lg:px-8">
              <div class="flex items-center justify-between h-16">
                <div class="flex items-center">
                  <!-- Mobile menu button -->
                  <button type="button" class="lg:hidden -ml-2 mr-2 p-2 rounded-md text-gray-400 hover:text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" data-action="click->sidebar#toggle">
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                    </svg>
                  </button>
                  <h1 class="text-lg font-semibold text-gray-900"><%= yield :page_title %></h1>
                </div>
                <div class="flex items-center gap-4">
                  <span class="text-sm text-gray-500"><%= current_user.business_name %></span>
                  <%= link_to "Cerrar sesión", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm text-gray-500 hover:text-gray-700" %>
                </div>
              </div>
            </div>
          </header>

          <!-- Page content -->
          <main class="flex-1 pt-16">
            <div class="px-4 sm:px-6 lg:px-8 py-8">
              <% if notice %>
                <div class="mb-4 rounded-md bg-green-50 p-4 border border-green-200" data-controller="notification" data-action="notification:disappear">
                  <p class="text-sm text-green-800"><%= notice %></p>
                </div>
              <% end %>
              <% if alert %>
                <div class="mb-4 rounded-md bg-red-50 p-4 border border-red-200" data-controller="notification" data-action="notification:disappear">
                  <p class="text-sm text-red-800"><%= alert %></p>
                </div>
              <% end %>
              <%= yield %>
            </div>
          </main>
        </div>
      </div>
    <% else %>
      <main class="min-h-screen flex items-center justify-center bg-gray-50">
        <div class="w-full max-w-md px-4">
          <%= yield %>
        </div>
      </main>
    <% end %>
  </body>
</html>