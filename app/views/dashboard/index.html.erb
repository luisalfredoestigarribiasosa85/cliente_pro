<% content_for :page_title, "Dashboard" %>

<!-- Stats Grid -->
<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4 mb-8">
  <!-- Total Customers -->
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <div class="flex items-center">
      <div class="flex-shrink-0 p-3 bg-indigo-50 rounded-lg">
        <svg class="h-6 w-6 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-500">Total Clientes</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @total_customers %></p>
      </div>
    </div>
  </div>

  <!-- Need Follow-up -->
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <div class="flex items-center">
      <div class="flex-shrink-0 p-3 bg-yellow-50 rounded-lg">
        <svg class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-500">Requieren Seguimiento</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @customers_needing_follow_up %></p>
      </div>
    </div>
  </div>

  <!-- Pending Reminders -->
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <div class="flex items-center">
      <div class="flex-shrink-0 p-3 bg-orange-50 rounded-lg">
        <svg class="h-6 w-6 text-orange-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-500">Recordatorios Vencidos</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @overdue_reminders %></p>
      </div>
    </div>
  </div>

  <!-- By Status -->
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <div class="flex items-center">
      <div class="flex-shrink-0 p-3 bg-green-50 rounded-lg">
        <svg class="h-6 w-6 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
        </svg>
      </div>
      <div class="ml-4">
        <p class="text-sm font-medium text-gray-500">Clientes Frecuentes</p>
        <p class="text-2xl font-semibold text-gray-900"><%= @customers_by_status["frequent"] || 0 %></p>
      </div>
    </div>
  </div>
</div>

<!-- Charts & Lists -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
  <!-- Status Distribution -->
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <h3 class="text-base font-semibold text-gray-900 mb-4">Clientes por Estado</h3>
    <div class="space-y-3">
      <% { "new" => "Nuevos", "interested" => "Interesados", "frequent" => "Frecuentes", "lost" => "Perdidos" }.each do |key, label| %>
        <% count = @customers_by_status[key] || 0 %>
        <% max_count = @customers_by_status.values.max || 1 %>
        <% percentage = max_count > 0 ? (count.to_f / max_count * 100).round : 0 %>
        <div>
          <div class="flex justify-between text-sm mb-1">
            <span class="text-gray-600"><%= label %></span>
            <span class="font-medium text-gray-900"><%= count %></span>
          </div>
          <div class="w-full bg-gray-100 rounded-full h-2">
            <div class="h-2 rounded-full <%= {'new' => 'bg-blue-500', 'interested' => 'bg-yellow-500', 'frequent' => 'bg-green-500', 'lost' => 'bg-red-500'}[key] %>" style="width: <%= percentage %>%"></div>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Recent Customers -->
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-base font-semibold text-gray-900">Clientes Recientes</h3>
      <%= link_to "Ver todos", customers_path, class: "text-sm text-indigo-600 hover:text-indigo-500" %>
    </div>
    <div class="space-y-3">
      <% @recent_customers.each do |customer| %>
        <%= link_to customer_path(customer), class: "block p-3 rounded-lg hover:bg-gray-50 border border-gray-100" do %>
          <div class="flex items-center justify-between">
            <div>
              <p class="text-sm font-medium text-gray-900"><%= customer.name %></p>
              <p class="text-xs text-gray-500"><%= customer.phone %></p>
            </div>
            <div>
              <%= status_badge(customer.status) %>
            </div>
          </div>
        <% end %>
      <% end %>
      <% if @recent_customers.empty? %>
        <p class="text-sm text-gray-500 text-center py-4">No hay clientes todavía. <%= link_to "Agrega tu primer cliente", new_customer_path, class: "text-indigo-600 hover:text-indigo-500" %></p>
      <% end %>
    </div>
  </div>

  <!-- Pending Reminders -->
  <div class="bg-white rounded-xl border border-gray-200 p-6 lg:col-span-2">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-base font-semibold text-gray-900">Próximos Recordatorios</h3>
      <%= link_to "Ver todos", reminders_path, class: "text-sm text-indigo-600 hover:text-indigo-500" %>
    </div>
    <div class="space-y-3">
      <% @pending_reminders.each do |reminder| %>
        <div class="flex items-center justify-between p-3 rounded-lg border border-gray-100">
          <div class="flex items-center gap-3">
            <div class="flex-shrink-0 w-2 h-2 rounded-full <%= reminder.remind_at < Time.current ? 'bg-red-400' : 'bg-yellow-400' %>"></div>
            <div>
              <p class="text-sm font-medium text-gray-900"><%= reminder.message %></p>
              <p class="text-xs text-gray-500">
                <%= reminder.customer.name %> &middot; <%= l(reminder.remind_at, format: :short) rescue reminder.remind_at.strftime("%d/%m %H:%M") %>
              </p>
            </div>
          </div>
          <%= link_to toggle_done_reminder_path(reminder), data: { turbo_method: :patch }, class: "text-xs text-gray-400 hover:text-green-600" do %>
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          <% end %>
        </div>
      <% end %>
      <% if @pending_reminders.empty? %>
        <p class="text-sm text-gray-500 text-center py-4">No hay recordatorios pendientes. <%= link_to "Crear recordatorio", new_reminder_path, class: "text-indigo-600 hover:text-indigo-500" %></p>
      <% end %>
    </div>
  </div>
</div>